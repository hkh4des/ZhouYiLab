<template>
  <view class="app">
    <view>
      <text>你自己的业务系统订单详情页面</text>
    </view>
    <view style="margin-top: 10px;">
      <text>order_no：{{ myOptions['order_no'] }}</text>
    </view>
    <view style="margin-top: 10px;">
      <text>out_trade_no：{{ myOptions['out_trade_no'] }}</text>
    </view>
  </view>
</template>

<script setup>
  import { reactive } from 'vue'
  const myOptions = reactive({} as UTSJSONObject)

  onLoad((options) => {
    console.log('options: ', options)
    myOptions['order_no'] = options['order_no'] as string
    myOptions['out_trade_no'] = options['out_trade_no'] as string
  })
</script>

<style lang="scss" scoped>
  .app {
    padding: 15px;
  }
</style>
