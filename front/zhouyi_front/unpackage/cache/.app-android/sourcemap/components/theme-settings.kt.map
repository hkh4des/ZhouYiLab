		<view class="settings-section">
			<view class="setting-item">
				<view class="setting-label">
					<text class="label-text">дә”иЎҢй…ҚиүІ</text>
					<text class="label-desc">жҢүдә”иЎҢеұһжҖ§жҳҫзӨәйўңиүІ</text>
				</view>
				<switch :checked="enableWuxingColors" @change="onWuxingColorsChange" />
			</view>
		</view>
		
		<view class="settings-section">
			<text class="section-title">дә”иЎҢйўңиүІйў„и§Ҳ</text>
			<view class="wuxing-preview">
				<view class="wuxing-item">
					<text class="wuxing-mu">жңЁ</text>
