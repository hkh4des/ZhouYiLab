					{ relation: '财', dunGan: '壬', branch: '戌', general: '雀' },
					{ relation: '父', dunGan: '己', branch: '子', general: '贵' }
				],
				
				// 四课数据
				siKe: {
					generals: ['蛇', '青', '勾', '常'],
					heavenPlate: ['戌', '午', '未', '卯'],
					earthPlate: ['午', '寅', '卯', '壬']
				},
				
				// 排盘布局顺序 - 按行定义地支显示顺序
