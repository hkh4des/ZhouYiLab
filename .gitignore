# Ignore all dotfiles and dotfolders
.*

# Except git-related files
!.git
!.gitignore
!.gitattributes
!.gitmodules
!.github

# Build directories
build/
cmake-build-*/
out/
bin/
lib/

# CMake generated files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps/
*.ninja
*.ninja_deps
*.ninja_log
cmake-build-*

# Build artifacts
*.exe
*.out
*.app
*.dll
*.so
*.dylib
*.a
*.lib
*.o
*.obj

# IDE specific files
*.swp
*.swo
*~

# Visual Studio
*.user
*.suo
*.userosscache
*.sln.docstates
*.vcxproj
*.vcxproj.filters
*.sln
*.ilk
*.pdb

# Testing
Testing/
*.log

# Package managers
conan/
vcpkg_installed/

# Temporary files
*.tmp
*.temp
*.bak
*.cache

# Other
front/
